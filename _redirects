# Proxy all list share links to the backend.
# The backend's renderSharedListPage() queries Supabase with the admin client
# (already configured in Render) — no Netlify env vars required.
#
# /shared/:token  — legacy format; kept for old links / QR codes
# /s/:username/:token — pretty format generated by the mobile app
/shared/*  https://qulture-backend-api.onrender.com/shared/:splat  200
/s/*       https://qulture-backend-api.onrender.com/s/:splat       200

/shared-plan/*   /shared-plan/index.html   200

# Canonical list share URL — served by local HTML that fetches from the
# get-shared-list Netlify function; no backend proxy needed.
/shared-list/*   /shared-list/index.html   200

# Taste snapshot links — proxied to the backend HTML renderer.
# Token URLs: qulture.app/taste/{token}
/taste/*  https://qulture-backend-api.onrender.com/taste/:splat  200

# Personalized taste snapshot slug URLs: qulture.app/q/{slug}
/q/*  https://qulture-backend-api.onrender.com/q/:splat  200

# Taste snapshot token-based pages — served by the backend Express router.
/taste/*  https://qulture-backend-api.onrender.com/taste/:splat  200

# Proxy well-known verification files to the backend on Render.
# iOS reads apple-app-site-association to validate universal links (applinks).
# Android reads assetlinks.json to verify App Links (autoVerify).
/.well-known/apple-app-site-association  https://qulture-backend-api.onrender.com/.well-known/apple-app-site-association  200
/.well-known/assetlinks.json             https://qulture-backend-api.onrender.com/.well-known/assetlinks.json             200
